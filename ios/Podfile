# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

use_frameworks! :linkage => :static

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'ReactNativeDemo' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :hermes_enabled => false,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Xcode 26: fmt 11.0.2 consteval is broken with Apple Clang.
    # Line 122 only disables consteval for Apple Clang < 14, but Xcode 26's
    # Clang also triggers it via __cpp_consteval (line 126) AND
    # FMT_CLANG_VERSION >= 1101 (line 128). Fix: disable consteval for ALL
    # Apple Clang versions by removing the version check on line 122.
    fmt_base = "#{__dir__}/Pods/fmt/include/fmt/base.h"
    if File.exist?(fmt_base)
      text = File.read(fmt_base)
      patched = text.gsub(
        /defined\(__apple_build_version__\) && __apple_build_version__ < 14000029L/,
        'defined(__apple_build_version__)'
      )
      if patched != text
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
        Pod::UI.puts "[fmt] Disabled consteval for Apple Clang (Xcode 26 compatibility)"
      end
    end
  end
end

target 'InsiderNotificationContent' do
  use_frameworks!
  inherit! :search_paths
  # Pods for InsiderNotificationContent
  pod 'InsiderMobileAdvancedNotification'
end

target 'InsiderNotificationService' do
  use_frameworks!
  inherit! :search_paths
  # Pods for InsiderNotificationService
  pod 'InsiderMobileAdvancedNotification'
end
